{
  "productName": "Codex Control",
  "version": "0.1.0",
  "identifier": "com.rickenator.codex-control",
  "build": {
    "frontendDist": "../src/out",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Codex Control",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": []
  }
}
