{
  "name": "consiglio",
  "version": "0.1.1",
  "description": "A cross-platform desktop control plane for Codex-compatible agents.",
  "author": {
    "name": "Rick Goldberg, Aniviza LLC Productions",
    "email": "rick@aniviza.com"
  },
  "license": "Apache-2.0",
  "private": true,
  "main": "dist/main.js",
  "desktopName": "Consiglio",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --config vite.renderer.config.ts",
    "start": "electron .",
    "dev:all": "npm run build && npm run start",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/tsconfig.json",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/*.test.mts",
    "verify": "npm run typecheck && npm test && npm run build",
    "package": "electron-builder",
    "package:linux": "npm run verify && electron-builder --linux AppImage deb --publish never",
    "package:mac": "npm run verify && electron-builder --mac dmg zip --publish never",
    "package:win": "npm run verify && electron-builder --win nsis portable --publish never",
    "package:release:mac": "npm run verify && electron-builder --mac dmg zip --publish never -c.forceCodeSigning=true -c.mac.notarize=true",
    "package:release:win": "npm run verify && electron-builder --win nsis portable --publish never -c.forceCodeSigning=true",
    "validate:package": "node scripts/validate-package.mjs",
    "package:host": "node scripts/package-host.mjs"
  },
  "dependencies": {
    "node-pty": "^1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@types/node": "^26",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^7",
    "vite": "^8"
  },
  "build": {
    "appId": "com.rickenator.consiglio",
    "productName": "Consiglio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "executableName": "consiglio",
    "npmRebuild": true,
    "afterPack": "scripts/after-pack.cjs",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icons/icon.png",
      "synopsis": "Desktop control plane for Codex CLI",
      "description": "A native desktop control plane for Codex-compatible agents with session tracking, review tooling, provider health checks, and remote llama.cpp support.",
      "syncDesktopName": true
    },
    "deb": {
      "compression": "gz"
    },
    "files": [
      "dist/main.js",
      "dist/preload.js",
      "dist/renderer/**/*",
      "LICENSE",
      "NOTICE"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*.node"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons"
      }
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.png",
      "minimumSystemVersion": "12.0.0",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.png"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-${arch}-portable.${ext}"
    }
  }
}
