{
  "name": "consiglio",
  "version": "0.1.0",
  "description": "A cross-platform desktop control plane for Codex-compatible agents.",
  "author": "Rick <rick@apex>",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:native": "node-gyp rebuild --directory native",
    "dev": "vite --config vite.renderer.config.ts",
    "start": "electron .",
    "dev:all": "npm run build && npm run start",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "package": "electron-builder",
    "package:appimage": "electron-builder --linux AppImage",
    "package:deb": "bash scripts/package-deb.sh",
    "package:linux": "npm run build && npm run package:appimage && npm run package:deb",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:all": "electron-builder --mac --win --linux"
  },
  "dependencies": {
    "better-sqlite3": "^11",
    "bonjour-service": "^1.4.3",
    "node-addon-api": "^8.0.0",
    "node-pty": "^1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1",
    "@types/better-sqlite3": "^7",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "electron": "^33",
    "electron-builder": "^25",
    "node-gyp": "^11",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5",
    "vite": "^6",
    "wait-on": "^8"
  },
  "build": {
    "appId": "com.rickenator.consiglio",
    "productName": "Consiglio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "executableName": "consiglio",
    "electronDist": "node_modules/electron/dist",
    "npmRebuild": false,
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icons/icon.png",
      "synopsis": "Desktop control plane for Codex CLI",
      "description": "A native desktop control plane for Codex-compatible agents with session tracking, review tooling, provider health checks, and remote llama.cpp support."
    },
    "deb": {
      "compression": "gz"
    },
    "files": [
      "dist/main.js",
      "dist/preload.js",
      "dist/renderer/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*.node"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons"
      }
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.png"
    }
  }
}
